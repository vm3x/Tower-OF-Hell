toggleBtn.MouseButton1Click:Connect(function()
    teleportEnabled = not teleportEnabled
    if teleportEnabled then
        toggleBtn.Text = "ВЫКЛ"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(120, 30, 30)
        status.Text = "Статус: Активен"
        status.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        totalLevels = getCurrentLevel()
        currentLevel = 0
        print("Всего уровней:", totalLevels)
        print("Авто-телепорт включён")
        
        spawn(function()
            while teleportEnabled do
                pcall(function()
                    checkCurrentLevel()
                    -- Если не на платформе, пробуем телепорт на ближайший доступный уровень
                    local nextPlatform = getNextLevelPlatform()
                    if not nextPlatform then
                        -- Если нет следующего уровня, пытаемся найти любой доступный
                        local tower = workspace:FindFirstChild("Tower")
                        if tower then
                            for _, child in ipairs(tower:GetChildren()) do
                                if child:IsA("Model") and child.Name:match("Level") then
                                    local num = tonumber(child.Name:match("%d+"))
                                    if num and num > currentLevel then
                                        for _, part in ipairs(child:GetDescendants()) do
                                            if part:IsA("BasePart") and part.Name == "Platform" then
                                                local dist = (hrp.Position - part.Position).Magnitude
                                                if dist > 30 then
                                                    hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 5, 0))
                                                    currentLevel = num
                                                    print("Телепорт на уровень:", currentLevel)
                                                end
                                                break
                                            end
                                        end
                                        break
                                    end
                                end
                            end
                        end
                    end
                end)
                task.wait(1)
            end
        end)
    else
        toggleBtn.Text = "ВКЛ"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 120, 60)
        status.Text = "Статус: Выкл"
        status.TextColor3 = Color3.fromRGB(200, 200, 200)
        print("Авто-телепорт выключён")
    end
end)

