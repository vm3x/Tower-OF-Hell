-- Tower of Hell Auto Teleport to Next Level
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local RunService = game:GetService("RunService")

local teleportEnabled = false
local currentLevel = 0
local totalLevels = 0

local function getCurrentLevel()
    local tower = workspace:FindFirstChild("Tower")
    if not tower then return 0 end
    
    local highest = 0
    for _, child in ipairs(tower:GetChildren()) do
        if child:IsA("Model") and child.Name:match("Level") then
            local num = tonumber(child.Name:match("%d+"))
            if num and num > highest then
                highest = num
            end
        end
    end
    return highest
end

local function getNextLevelPlatform()
    local tower = workspace:FindFirstChild("Tower")
    if not tower then return nil end
    
    local nextLevelNum = currentLevel + 1
    local levelName = "Level" .. nextLevelNum
    
    for _, child in ipairs(tower:GetChildren()) do
        if child:IsA("Model") and child.Name == levelName then
            for _, part in ipairs(child:GetDescendants()) do
                if part:IsA("BasePart") and part.Name == "Platform" then
                    return part
                end
            end
        end
    end
    return nil
end

local function teleportToLevel()
    local target = getNextLevelPlatform()
    if not target then
        print("Не найден уровень " .. (currentLevel + 1))
        return
    end
    
    local pos = target.Position + Vector3.new(0, 5, 0)
    hrp.CFrame = CFrame.new(pos)
    currentLevel = currentLevel + 1
    print("Телепорт на уровень:", currentLevel)
end

local function checkCurrentLevel()
    local tower = workspace:FindFirstChild("Tower")
    if not tower then return end
    
    for _, child in ipairs(tower:GetChildren()) do
        if child:IsA("Model") and child.Name:match("Level") then
            local num = tonumber(child.Name:match("%d+"))
            if num and num > currentLevel then
                -- Проверяем, находится ли игрок на этой платформе
                for _, part in ipairs(child:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name == "Platform" then
                        local dist = (hrp.Position - part.Position).Magnitude
                        if dist < 20 then
                            currentLevel = num
                            print("На уровне:", currentLevel)
                            -- Телепортируем на следующий
                            task.wait(0.5)
                            teleportToLevel()
                            return
                        end
                    end
                end
            end
        end
    end
end

